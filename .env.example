LOGIN_EMAIL=YOUR_EMAIL
LOGIN_PASSWORD=YOUR_PASSWORD

# On secondary clones: set POPULATE_TEACHERS=false AND point TEACHERS_CACHE_PATH at
# the primary clone's teachers.json. Both must be set together.
# POPULATE_TEACHERS=false
# TEACHERS_CACHE_PATH=/absolute/path/to/primary/class_booker/teachers.json

# Pushover notifications (optional — leave blank to disable)
PUSHOVER_USER_KEY=YOUR_PUSHOVER_USER_KEY
PUSHOVER_API_TOKEN=YOUR_PUSHOVER_API_TOKEN
